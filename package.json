      "@myriaddreamin/typst-ts-renderer": "$@myriaddreamin/typst-ts-renderer",
      "@myriaddreamin/typst.ts": "$@myriaddreamin/typst.ts"
    }
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "sharp@0.35.1": true,
    "esbuild@0.28.1": true
