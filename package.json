    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/markdown-satteri": "^0.3.3",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.3",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@myriaddreamin/rehype-typst": "^0.7.0",
    "@myriaddreamin/typst-ts-node-compiler": "^0.7.0",
    "@myriaddreamin/typst-ts-renderer": "^0.7.0",
    "@myriaddreamin/typst.ts": "^0.7.0",
    "@tailwindcss/postcss": "^4.3.2",
    "astro": "^7.0.7",
    "astro-embed": "^0.13.1",
    "cheerio": "^1.2.0",
    "mermaid": "^11.16.0",
    "playwright": "^1.61.1",
    "rehype-mermaid": "^3.0.0",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.2",
    "sharp": "^0.35.3",
    "starlight-links-validator": "^0.25.2",
    "starlight-showcases": "^0.3.2",
    "starlight-sidebar-topics": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "unified": "^11.0.5"
