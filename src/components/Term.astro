---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<div class="flex flex-col bg-white dark:bg-zinc-900 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] dark:shadow-[0_4px_24px_rgba(0,0,0,0.4)] border border-slate-200 dark:border-white/10 overflow-hidden transition-all duration-300 ease-out hover:shadow-[0_10px_30px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_12px_32px_rgba(0,0,0,0.6)] hover:-translate-y-0.5">
  <dt class="bg-slate-50 dark:bg-zinc-800 py-5 px-6 border-b border-slate-200 dark:border-white/5 flex items-center">
    <div class="font-semibold text-[color:var(--sl-color-white)] text-[1.05rem] leading-snug">{title}</div>
  </dt>
  <dd class="m-0 py-5 px-6 text-[color:var(--sl-color-gray-2)] leading-relaxed text-[0.95rem] [&>p]:mt-0 [&>p]:mb-2 [&>p:last-child]:mb-0">
    <slot />
  </dd>
</div>
