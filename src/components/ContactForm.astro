---
---

<form action="https://ssgform.com/s/QniZPKX8gsfs" method="post">
  <div class="mt-10 sm:mt-20 mx-auto max-w-3xl px-4 sm:px-0">
    
    <!-- Name Field -->
    <div class="border-t border-gray-300 dark:border-zinc-700 py-4 sm:py-6 w-full flex flex-wrap sm:flex-nowrap items-center">
      <p class="w-full sm:max-w-[248px] tracking-wider font-bold text-[15px] sm:text-lg flex items-center dark:text-gray-200">
        <span class="rounded sm:rounded-md mr-2 py-1 sm:py-2 w-8 sm:w-12 inline-block text-center bg-[#5bc8ac] text-white text-[10px] sm:text-sm">
          必須
        </span>
        name
      </p>
      <input 
        type="text" 
        name="お名前" 
        class="border border-gray-300 dark:border-zinc-700 rounded-md mt-4 sm:mt-0 sm:ml-10 px-4 h-10 sm:h-12 flex-1 w-full sm:max-w-[410px] bg-[#eaedf2] dark:bg-zinc-800 dark:text-gray-100 text-[15px] sm:text-lg focus:outline-none focus:ring-2 focus:ring-[#5bc8ac]" 
      />
    </div>

    <!-- Email Field -->
    <div class="border-t border-gray-300 dark:border-zinc-700 py-4 sm:py-6 w-full flex flex-wrap sm:flex-nowrap items-center">
      <p class="w-full sm:max-w-[248px] tracking-wider font-bold text-[15px] sm:text-lg flex items-center dark:text-gray-200">
        <span class="rounded sm:rounded-md mr-2 py-1 sm:py-2 w-8 sm:w-12 inline-block text-center bg-[#5bc8ac] text-white text-[10px] sm:text-sm">
          必須
        </span>
        e-mail address
      </p>
      <input 
        type="email" 
        name="メールアドレス" 
        class="border border-gray-300 dark:border-zinc-700 rounded-md mt-4 sm:mt-0 sm:ml-10 px-4 h-10 sm:h-12 flex-1 w-full sm:max-w-[410px] bg-[#eaedf2] dark:bg-zinc-800 dark:text-gray-100 text-[15px] sm:text-lg focus:outline-none focus:ring-2 focus:ring-[#5bc8ac]" 
      />
    </div>

    <!-- Message Field -->
    <div class="border-y border-gray-300 dark:border-zinc-700 py-4 sm:py-6 w-full flex flex-wrap sm:flex-nowrap items-start">
      <p class="w-full sm:max-w-[248px] tracking-wider font-bold text-[15px] sm:text-lg flex items-center sm:mt-2 sm:mb-auto dark:text-gray-200">
        <span class="rounded sm:rounded-md mr-2 py-1 sm:py-2 w-8 sm:w-12 inline-block text-center bg-[#5bc8ac] text-white text-[10px] sm:text-sm">
          必須
        </span>
        お問い合わせ内容
      </p>
      <textarea 
        name="お問い合わせ内容" 
        class="border border-gray-300 dark:border-zinc-700 rounded-md mt-4 sm:mt-0 sm:ml-10 px-4 py-3 h-[200px] sm:h-[216px] flex-1 w-full sm:max-w-[410px] bg-[#eaedf2] dark:bg-zinc-800 dark:text-gray-100 text-[15px] sm:text-lg resize-y focus:outline-none focus:ring-2 focus:ring-[#5bc8ac]"
      ></textarea>
    </div>

    <!-- Submit Button -->
    <input 
      type="submit" 
      value="Send" 
      class="rounded-md mt-6 sm:mt-8 mx-auto py-2 sm:py-5 w-40 sm:w-[280px] block tracking-wider bg-[#5bc8ac] hover:bg-[#4ab599] transition-colors text-white font-bold text-base sm:text-xl cursor-pointer" 
    />
  </div>
</form>
