---
import type { StarlightRouteData as Props } from '@astrojs/starlight/route-data';
import Default from '@astrojs/starlight/components/Footer.astro';

import PreferredSourceBadge from '../widgets/PreferredSourceBadge.astro';
import MobileExploreButton from '../widgets/MobileExploreButton.astro';

const hasSidebar = Astro.locals.starlightRoute?.hasSidebar ?? Astro.props.hasSidebar;
---

<Default><slot /></Default>

<PreferredSourceBadge />

{hasSidebar && (
  <>
    <MobileExploreButton />
    <hr color="#EEEEEE" />
  </>
)}
