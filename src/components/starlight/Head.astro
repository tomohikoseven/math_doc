---
import Default from "@astrojs/starlight/components/Head.astro";

// サイトの基本情報を取得
const { entry, siteTitle } = Astro.locals.starlightRoute;

// アイキャッチ画像URL
const ogImageUrl = new URL("/favicon_option_a_m.svg", Astro.site).href;

// Schema.org JSON-LD
const baseSchema = {
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  author: {
    "@type": "Person",
    name: "tomohikoseven",
    url: "https://x.com/tomohikoseven",
  },
  datePublished:
    entry.data.lastUpdated instanceof Date
      ? entry.data.lastUpdated.toISOString()
      : new Date().toISOString(),
  publisher: {
    "@type": "Organization",
    name: siteTitle,
    logo: {
      "@type": "ImageObject",
      url: new URL("/favicon.ico", Astro.site).href,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": Astro.url.href,
  },
};

let schema;
const customSchema = entry.data.schema;

if (Array.isArray(customSchema)) {
  schema = {
    "@context": "https://schema.org",
    "@graph": [baseSchema, ...customSchema],
  };
} else {
  schema = {
    "@context": "https://schema.org",
    ...baseSchema,
    ...customSchema,
  };
}
---

<!-- Starlightのデフォルト<Head/>コンポーネント -->
<Default><slot /></Default>

<!-- Schema.org JSON-LD -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(schema)}
/>

<!-- Open Graphのアイキャッチ画像 -->
<meta property="og:image" content={ogImageUrl} />
<meta name="twitter:image" content={ogImageUrl} />
