---
import Default from '@astrojs/starlight/components/Head.astro'
import { getCldOgImageUrl } from 'astro-cloudinary/helpers'

// Grab the current page entry and site title from the page data.
const { entry, siteTitle } = Astro.locals.starlightRoute;

// Get the URL of the generated image for the current page.
const ogImageUrl = getCldOgImageUrl({
  // The public ID of the image in Cloudinary.
  src: 'blackboard_wmeehz',
  // Text overlays to add to the image.
  overlays: [
    {
      text: {
        // Add the title of the current page as text.
        text: entry.data.title,
        // Style the title text.
        color: '#FFFFFF',
        fontFamily: 'Sawarabi Gothic',
        fontSize: 65,
      },
      // Position the title with some padding.
      crop: 'fit',
      // position: { y: -20 },
      width: 1100,
    },
  ],
})

// Schema.org JSON-LD
const baseSchema = {
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "author": {
    "@type": "Person",
    "name": "tomohikoseven",
    "url": "https://x.com/tomohikoseven"
  },
  "datePublished": entry.data.lastUpdated instanceof Date ? entry.data.lastUpdated.toISOString() : new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": siteTitle,
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon.ico', Astro.site).href
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

let schema;
const customSchema = entry.data.schema;

if (Array.isArray(customSchema)) {
  schema = {
    "@context": "https://schema.org",
    "@graph": [
      baseSchema,
      ...customSchema
    ]
  };
} else {
  schema = {
    "@context": "https://schema.org",
    ...baseSchema,
    ...customSchema
  };
}
---

<!-- Render the default <Head/> component. -->
<Default><slot /></Default>

<!-- Schema.org JSON-LD -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

<!-- Render the <meta/> tags for the Open Graph images. -->
<meta property="og:image" content={ogImageUrl} />
<meta name="twitter:image" content={ogImageUrl} />