---
---
<div style={{ display: 'grid', gridTemplateColumns: '1fr 2fr', border: '1px solid var(--sl-color-gray-5)', borderRadius: '8px', textAlign: 'center', margin: '2rem 0', overflow: 'hidden' }}>
  <div style={{ padding: '24px 8px', borderRight: '1px solid var(--sl-color-gray-5)', borderBottom: '1px solid var(--sl-color-gray-5)', display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center' }}>
    <span style={{ fontSize: '1.1em', fontWeight: 'bold', color: 'var(--sl-color-white)' }}>キュー欄</span>
    <span style={{ fontSize: '0.85em', color: 'var(--sl-color-gray-3)', marginTop: '4px' }}>（要点・質問）</span>
  </div>
  <div style={{ padding: '48px 8px', borderBottom: '1px solid var(--sl-color-gray-5)', display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center' }}>
    <span style={{ fontSize: '1.1em', fontWeight: 'bold', color: 'var(--sl-color-white)' }}>ノート欄</span>
    <span style={{ fontSize: '0.85em', color: 'var(--sl-color-gray-3)', marginTop: '4px' }}>（授業内容）</span>
  </div>
  <div style={{ gridColumn: '1 / -1', padding: '16px 8px', display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center' }}>
    <span style={{ fontSize: '1.1em', fontWeight: 'bold', color: 'var(--sl-color-white)' }}>サマリー欄</span>
    <span style={{ fontSize: '0.85em', color: 'var(--sl-color-gray-3)', marginTop: '4px' }}>（まとめ）</span>
  </div>
</div>
