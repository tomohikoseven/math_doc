---
/**
 * 定理、定義、具体例、FAQなど、重要度の高い主張や文章のブロックを
 * バリアント（種類）ごとに色分けして目立たせるためのコンポーネント。
 * Statementsコンポーネント内で使用される。
 */
interface Props {
  title: string;
  icon?: string;
  variant?: 'term' | 'definition' | 'theorem' | 'example' | 'faq';
}
const { title, icon, variant = 'term' } = Astro.props;
---
<div class={`statement-item variant-${variant}`}>
  <dt class="statement-title">
    {icon && <span class="statement-icon" set:html={icon} />}
    {title}
  </dt>
  <dd class="statement-desc">
    <slot />
  </dd>
</div>

<style>
  .statement-item {
    background-color: #ffffff;
    border-radius: 0;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    border-left-width: 4px; /* 左側だけ太くする */
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .statement-item:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  
  /* ダークモードの上書き（全辺の border-color を設定） */
  :global([data-theme="dark"]) .statement-item {
    background-color: #18181b; /* Zinc 900 */
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  :global([data-theme="dark"]) .statement-item:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.6);
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* --- バリアント（左線の色） --- */
  /* 詳細度を高くすることで、ダークモードの border-color に負けないようにする */
  :global(:root) .statement-item.variant-term {
    border-left-color: var(--sl-color-gray-4, #9ca3af);
  }
  :global(:root) .statement-item.variant-definition {
    border-left-color: #eab308;
  }
  :global(:root) .statement-item.variant-theorem {
    border-left-color: var(--sl-color-green, #22c55e);
  }
  :global(:root) .statement-item.variant-example {
    border-left-color: var(--sl-color-purple, #a855f7);
  }
  :global(:root) .statement-item.variant-faq {
    border-left-color: var(--sl-color-blue, #3b82f6);
  }

  .statement-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1.4;
  }
  
  .statement-desc {
    margin: 0;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  
  .statement-desc :global(p) {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  
  .statement-desc :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
