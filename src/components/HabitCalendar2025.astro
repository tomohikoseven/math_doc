</style>

<script>
  function initStaticTooltip2025() {
    const tooltip = document.getElementById("calendar-tooltip-2025");
    const container = document.getElementById("calendar-2025");
    if (!tooltip || !container || container.dataset.tooltipInitialized) return;

    container.addEventListener("mouseover", (e) => {
      const target = e.target;
      if (target instanceof HTMLElement && target.classList.contains("day-cell")) {
        const date = target.getAttribute("data-date");
        const time = target.getAttribute("data-time");
        if (date && time) {
          tooltip.textContent = date + ": " + time + " 勉強しました";
          tooltip.style.opacity = "1";
          
          const rect = target.getBoundingClientRect();
          const tooltipWidth = tooltip.offsetWidth;
          tooltip.style.left = (rect.left - tooltipWidth / 2 + 6) + "px";
          tooltip.style.top = (rect.top - 55) + "px";
        }
      }
    });

    container.addEventListener("mouseout", (e) => {
      if (e.target instanceof HTMLElement && e.target.classList.contains("day-cell")) {
        tooltip.style.opacity = "0";
      }
    });

    container.dataset.tooltipInitialized = "true";
  }

  document.addEventListener("astro:page-load", initStaticTooltip2025);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initStaticTooltip2025);
  } else {
    initStaticTooltip2025();
  }
</script>
