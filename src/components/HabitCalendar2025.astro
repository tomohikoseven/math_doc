<style>
  .habit-calendar-container {
    --bg-0: #ebedf0;
    --bg-1: #9be9a8;
    --bg-2: #40c463;
    --bg-3: #30a14e;
    --bg-4: #216e39;
    --text-color: #57606a;
    --cell-size: 12px;
    --cell-gap: 3px;
    --label-font-size: 10px;

    background: var(--sl-color-bg-elevated, #fff);
    border: 1px solid var(--sl-color-gray-5, #d0d7de);
    border-radius: 12px;
    padding: 24px;
    margin: 2rem auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    font-family: var(--sl-font-system);
    width: max-content;
    max-width: 100%;
    box-sizing: border-box;
  }

  :global([data-theme="dark"]) .habit-calendar-container {
    --bg-0: #161b22;
    --bg-1: #0e4429;
    --bg-2: #006d32;
    --bg-3: #26a641;
    --bg-4: #39d353;
    --text-color: #8b949e;
    border-color: #30363d;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .total-stats {
    font-weight: 600;
    font-size: 1rem;
    color: var(--sl-color-text);
  }

  .calendar-outer-wrapper {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .weekday-labels {
    display: grid;
    grid-template-rows: repeat(7, var(--cell-size));
    gap: var(--cell-gap);
    margin-top: 18px;
    font-size: var(--label-font-size);
    color: var(--text-color);
  }

  .label-day {
    height: var(--cell-size);
    line-height: var(--cell-size);
    display: flex;
    align-items: center;
  }

  .calendar-scroll-wrapper {
    overflow-x: auto;
    padding-bottom: 12px;
    scrollbar-width: thin;
    scroll-behavior: smooth;
    flex: 1;
  }

  .month-labels {
    font-size: var(--label-font-size);
    color: var(--text-color);
    margin-bottom: 6px;
    height: 12px;
    min-width: max-content;
  }

  .month-label {
    white-space: nowrap;
  }

  .calendar-grid {
    min-width: max-content;
    position: relative;
    padding: 0;
  }

  :global(.day-cell) {
    width: var(--cell-size);
    height: var(--cell-size);
    border-radius: 2px;
    background-color: var(--bg-0);
    transition: transform 0.1s ease;
    cursor: pointer;
    box-sizing: border-box;
    border: 1px solid rgba(0, 0, 0, 0.03);
  }

  :global([data-theme="dark"] .day-cell) {
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  :global(.day-cell:hover) {
    transform: scale(1.3);
    z-index: 10;
    opacity: 0.8;
  }

  :global(.day-cell.level-1) { background-color: var(--bg-1); }
  :global(.day-cell.level-2) { background-color: var(--bg-2); }
  :global(.day-cell.level-3) { background-color: var(--bg-3); }
  :global(.day-cell.level-4) { background-color: var(--bg-4); }

  .calendar-footer {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    margin-top: 16px;
    font-size: 12px;
    color: var(--text-color);
    padding-left: 36px;
  }

  .legend {
    display: flex;
    align-items: center;
    gap: 8px;
    height: var(--cell-size);
  }

  .legend span {
    line-height: var(--cell-size);
  }

  .legend-cells {
    display: flex;
    gap: var(--cell-gap);
    align-items: center;
  }

  .legend-cell {
    width: var(--cell-size);
    height: var(--cell-size);
    border-radius: 2px;
    border: 1px solid rgba(0, 0, 0, 0.03);
    box-sizing: border-box;
    display: block;
  }

  :global([data-theme="dark"]) .legend-cell {
    border: 1px solid rgba(255, 255, 255, 0.03);
