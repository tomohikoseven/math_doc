---
/**
 * HabitCalendar2025.astro
 * Fully static component with pre-rendered data for 2025.
 */
---
<div class="habit-calendar-container not-content" id="calendar-2025">
  <div class="calendar-header">
    <h3 id="total-study-time">合計勉強時間: 229.4 時間 (2025年)</h3>
  </div>

  <div class="calendar-outer-wrapper">
    <div class="weekday-labels">
      <span>Sun</span>
      <span>Mon</span>
      <span>Tue</span>
      <span>Wed</span>
      <span>Thu</span>
      <span>Fri</span>
      <span>Sat</span>
    </div>
    
    <div class="calendar-scroll-wrapper">
      <div class="month-labels" id="month-labels" style="display: grid; grid-template-columns: repeat(53, var(--cell-size)); grid-gap: var(--cell-gap);">
      <div class="month-label" style="grid-column-start: 1; width: 0; white-space: nowrap; font-size: 10px;">Jan</div>
      <div class="month-label" style="grid-column-start: 5; width: 0; white-space: nowrap; font-size: 10px;">Feb</div>
