      <div class="month-label" style="grid-column-start: 18; width: 0; white-space: nowrap; font-size: 10px;">May</div>
      <div class="month-label" style="grid-column-start: 23; width: 0; white-space: nowrap; font-size: 10px;">Jun</div>
      <div class="month-label" style="grid-column-start: 27; width: 0; white-space: nowrap; font-size: 10px;">Jul</div>
      <div class="month-label" style="grid-column-start: 31; width: 0; white-space: nowrap; font-size: 10px;">Aug</div>
      <div class="month-label" style="grid-column-start: 36; width: 0; white-space: nowrap; font-size: 10px;">Sep</div>
