---
import RakutenKujiDailyCard from './RakutenKujiDailyCard.astro';

interface LogEntry {
  date: string;
  points: number;
  sources: string[];
}
interface Props {
  data: LogEntry[];
}
const { data } = Astro.props;
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4 [&>*]:!mt-0">
  {
    data.map((entry) => (
      <RakutenKujiDailyCard
        date={entry.date}
        points={entry.points}
        sources={entry.sources}
      />
    ))
  }
</div>
