---
import RakutenKujiStatBox from "./RakutenKujiStatBox.astro";

interface Props {
  year: number | string;
  total: number | string;
  note?: string;
}

const { year, total, note } = Astro.props;
---

<RakutenKujiStatBox
  label={`${year}年 年間獲得ポイント合計`}
  value={total}
  unit="pt"
  size="large"
  wrapperClass="my-8"
>
  {note && (
    <div class="text-sm text-[var(--sl-color-gray-3)] mt-4">
      （※{note}）
    </div>
  )}
</RakutenKujiStatBox>
