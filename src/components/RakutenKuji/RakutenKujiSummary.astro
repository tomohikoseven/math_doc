---
import RakutenKujiStatBox from "./RakutenKujiStatBox.astro";

interface LogEntry {
  date: string;
  points: number;
  sources: string[];
}
interface Props {
  data: LogEntry[];
}
const { data } = Astro.props;

const totalPoints = data.reduce((sum, entry) => sum + entry.points, 0);
const daysWithWins = data.filter((entry) => entry.points > 0).length;
const highestWin = Math.max(...data.map((entry) => entry.points));
const avgPoints = (totalPoints / data.length).toFixed(1);
---

<div class="flex flex-col gap-4 mb-8 [&>*]:!mt-0">
  <RakutenKujiStatBox
    label="月間合計ポイント"
    value={totalPoints}
    unit="pt"
    size="large"
  />
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 [&>*]:!mt-0">
    <RakutenKujiStatBox
      label="当選日数 / 全体"
      value={daysWithWins}
      unit={`/ ${data.length} 日`}
    />
    <RakutenKujiStatBox
      label="1日の最大当選"
      value={highestWin}
      unit="pt"
    />
    <RakutenKujiStatBox
      label="1日平均"
      value={avgPoints}
      unit="pt/日"
    />
  </div>
</div>
