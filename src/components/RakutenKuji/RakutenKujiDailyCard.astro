---
import RakutenKujiBaseCard from "./RakutenKujiBaseCard.astro";

interface Props {
  date: string;
  points: number;
  sources: string[];
}

const { date, points, sources } = Astro.props;

function getPointVariant(
  points: number,
): "default" | "note" | "success" | "danger" | "tip" | "caution" {
  if (points === 0) return "default";
  if (points < 5) return "note";
  if (points < 50) return "success";
  return "danger";
}
---

<RakutenKujiBaseCard
  title={date.substring(5)}
  points={points}
  badgeVariant={getPointVariant(points)}
  opacityLow={points === 0}
>
  <div class="text-[0.9rem] text-[var(--sl-color-gray-2)] leading-[1.4]">
    {sources.length > 0 ? (
      sources.join("、")
    ) : (
      <span class="text-[var(--sl-color-gray-4)] italic">当選なし</span>
    )}
  </div>
</RakutenKujiBaseCard>
