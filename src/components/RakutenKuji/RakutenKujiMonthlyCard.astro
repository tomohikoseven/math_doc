---
import RakutenKujiBaseCard from "./RakutenKujiBaseCard.astro";

interface Props {
  year: number | string;
  month: number | string;
  points: number | string;
}

const { year, month, points } = Astro.props;
const monthStr = month.toString().padStart(2, '0');
const link = `/software/rakuten/${year}/rakuten_kuji_${year}${monthStr}`;

const numPoints = Number(points) || 0;

function getPointVariant(
  pts: number,
): "default" | "note" | "success" | "danger" | "tip" | "caution" {
  if (pts === 0) return "default";
  if (pts < 50) return "note";
  if (pts < 100) return "success";
  if (pts < 200) return "caution";
  return "danger";
}
---

<RakutenKujiBaseCard
  title={`${year}年${month}月`}
  points={points}
  badgeVariant={getPointVariant(numPoints)}
  opacityLow={numPoints === 0}
>
  <div class="text-[0.9rem] text-[var(--sl-color-gray-2)] leading-[1.4] text-right mt-2">
    <a href={link} class="no-underline text-[var(--sl-color-text-accent)] hover:underline">
      詳細はこちら ➔
    </a>
  </div>
</RakutenKujiBaseCard>
