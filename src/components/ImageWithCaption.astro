---
/**
 * 画像とそのキャプション（説明文）をセットで表示するためのコンポーネント。
 * AstroのImageコンポーネントをラップし、figure/figcaptionタグでセマンティックにマークアップする。
 */
import { Image } from 'astro:assets';

const { src, alt, width, height, figcaption } = Astro.props;
---

<figure>
    <Image
        src={src}
        alt={alt} 
        width={width} 
        height={height} 
    />
    <figcaption>{figcaption}</figcaption>
</figure>

<style>
  img {
    margin: auto;
  }
  figcaption {
    text-align: center;
    caption-side: bottom;
    margin: 0 !important;
    word-break: break-all;
    font-size: 0.8em;
    opacity: 0.8;
    padding: 0 6px;
  }
</style>